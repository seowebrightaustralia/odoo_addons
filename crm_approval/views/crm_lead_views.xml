<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_crm_approvals" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.crm.approvals</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="crm.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//app[@name='crm']" position="inside">
                <block title="Lead/Opportunity Approvals" name="crm_approvals_setting_container">
                    <setting help="Select the tags used for the CRM approval workflow.">
                        <div class="content-group">
                            <div class="row mt16">
                                <label for="crm_pending_tag_id" class="col-lg-3 o_light_label" string="Pending Tag"/>
                                <field name="crm_pending_tag_id"/>
                            </div>
                            <div class="row mt16">
                                <label for="crm_approved_tag_id" class="col-lg-3 o_light_label" string="Approved Tag"/>
                                <field name="crm_approved_tag_id"/>
                            </div>
                            <div class="row mt16">
                                <label for="crm_declined_tag_id" class="col-lg-3 o_light_label" string="Declined Tag"/>
                                <field name="crm_declined_tag_id"/>
                            </div>
                            <div class="row mt16">
                                <label for="crm_on_hold_tag_id" class="col-lg-3 o_light_label" string="On-Hold Tag"/>
                                <field name="crm_on_hold_tag_id"/>
                            </div>
                        </div>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>