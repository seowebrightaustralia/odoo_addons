<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_crm_lead_form_inherited_approval" model="ir.ui.view">
        <field name="name">crm.lead.form.inherited.approval</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='tag_ids']" position="after">
                <field name="approval_status" invisible="1"/>
            </xpath>

            <xpath expr="//header" position="inside">
                <button name="action_approve_lead" string="Approve" type="object" class="btn-success" invisible="approval_status == '2_approved'" groups="sales_team.group_sale_manager"/>
                <button name="action_decline_lead" string="Decline" type="object" class="btn-danger" invisible="approval_status == '3_declined'" groups="sales_team.group_sale_manager"/>
                <button name="action_on_hold_lead" string="On Hold" type="object" class="btn-warning" invisible="approval_status == '4_on_hold'" groups="sales_team.group_sale_manager"/>
                <button name="action_reset_pending" string="Reset to Pending" type="object" invisible="approval_status == '1_pending'" groups="sales_team.group_sale_manager"/>
            </xpath>
            
            <xpath expr="//div[hasclass('oe_title')]" position="before">
                <div class="mb-2">
                    <span class="badge rounded-pill text-bg-success fs-6 py-2 px-3" invisible="approval_status != '2_approved'">
                        <i class="fa fa-check me-1"/> Approved
                    </span>
                    <span class="badge rounded-pill text-bg-danger fs-6 py-2 px-3" invisible="approval_status != '3_declined'">
                        <i class="fa fa-times me-1"/> Declined
                    </span>
                    <span class="badge rounded-pill text-bg-warning fs-6 py-2 px-3" invisible="approval_status != '4_on_hold'">
                        <i class="fa fa-pause me-1"/> On Hold
                    </span>
                </div>
            </xpath>
        </field>
    </record>

    <record id="view_crm_lead_kanban_inherited_approval" model="ir.ui.view">
        <field name="name">crm.lead.kanban.inherited.approval</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_case_kanban_view_leads"/>
        <field name="arch" type="xml">
            <xpath expr="//templates" position="before">
                <field name="approval_status"/>
            </xpath>
            
            <xpath expr="//templates//field[@name='tag_ids']" position="after">
                <div class="d-flex mt-2 mb-1">
                    <button name="action_approve_lead" type="object" class="btn btn-sm btn-outline-success me-1 p-1" invisible="approval_status == '2_approved'" groups="sales_team.group_sale_manager" title="Approve">
                        <i class="fa fa-check"/>
                    </button>
                    <button name="action_decline_lead" type="object" class="btn btn-sm btn-outline-danger me-1 p-1" invisible="approval_status == '3_declined'" groups="sales_team.group_sale_manager" title="Decline">
                        <i class="fa fa-times"/>
                    </button>
                    <button name="action_on_hold_lead" type="object" class="btn btn-sm btn-outline-warning p-1" invisible="approval_status == '4_on_hold'" groups="sales_team.group_sale_manager" title="On Hold">
                        <i class="fa fa-pause"/>
                    </button>
                </div>
            </xpath>
        </field>
    </record>

    <record id="view_crm_lead_search_inherited_approval" model="ir.ui.view">
        <field name="name">crm.lead.search.inherited.approval</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.view_crm_case_leads_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//search" position="inside">
                <separator/>
                <filter string="Active Leads Only" name="filter_active_leads" domain="[('active', '=', True)]"/>
                <separator/>
                
                <filter string="Today" name="filter_today" domain="[('create_date', '&gt;=', context_today().strftime('%Y-%m-%d 00:00:00')), ('create_date', '&lt;=', context_today().strftime('%Y-%m-%d 23:59:59'))]"/>
                <filter string="Yesterday" name="filter_yesterday" domain="[('create_date', '&gt;=', (context_today() - relativedelta(days=1)).strftime('%Y-%m-%d 00:00:00')), ('create_date', '&lt;=', (context_today() - relativedelta(days=1)).strftime('%Y-%m-%d 23:59:59'))]"/>
                <separator/>
                
                <filter string="This Week" name="filter_this_week" domain="[
                    ('create_date', '&gt;=', (context_today() + relativedelta(weeks=-1,days=1,weekday=0)).strftime('%Y-%m-%d 00:00:00')),
                    ('create_date', '&lt;=', (context_today() + relativedelta(weekday=6)).strftime('%Y-%m-%d 23:59:59'))]"/>
                <filter string="Last Week" name="filter_last_week" domain="[
                    ('create_date', '&gt;=', (context_today() + relativedelta(weeks=-2,days=1,weekday=0)).strftime('%Y-%m-%d 00:00:00')),
                    ('create_date', '&lt;=', (context_today() + relativedelta(weeks=-1,weekday=6)).strftime('%Y-%m-%d 23:59:59'))]"/>
                <separator/>
                
                <filter string="This Month" name="filter_this_month" domain="[('create_date', '&gt;=', context_today().strftime('%Y-%m-01 00:00:00')), ('create_date', '&lt;=', (context_today() + relativedelta(months=1, day=1, days=-1)).strftime('%Y-%m-%d 23:59:59'))]"/>
                <filter string="Last Month" name="filter_last_month" domain="[('create_date', '&gt;=', (context_today() - relativedelta(months=1)).strftime('%Y-%m-01 00:00:00')), ('create_date', '&lt;', context_today().strftime('%Y-%m-01 00:00:00'))]"/>
                <filter string="Last 3 Months" name="filter_last_3_months" domain="[('create_date', '&gt;=', (context_today() - relativedelta(months=3)).strftime('%Y-%m-01 00:00:00'))]"/>
                <separator/>
                
                <filter string="This Year" name="filter_this_year" domain="[('create_date', '&gt;=', context_today().strftime('%Y-01-01 00:00:00'))]"/>
                <separator/>

                <filter string="Dynamic Dates Generator (Years/Months)" name="filter_dynamic_dates" date="create_date"/>
                <separator/>
                
                <group expand="0" string="Approval Options">
                    <filter string="Approval Status" name="group_by_approval_status" context="{'group_by': 'approval_status'}"/>
                    <filter string="Creation Month" name="group_by_month" context="{'group_by': 'create_date:month'}"/>
                </group>
            </xpath>
        </field>
    </record>

    <record id="action_crm_lead_approvals" model="ir.actions.act_window">
        <field name="name">CRM Approvals</field>
        <field name="res_model">crm.lead</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="context">{
            'search_default_filter_active_leads': 1,
            'group_by': 'approval_status'
        }</field>
    </record>

    <menuitem id="menu_crm_lead_approvals" 
              name="CRM Approvals" 
              action="action_crm_lead_approvals" 
              web_icon="crm,static/description/icon.png"
              sequence="16"/>

</odoo>